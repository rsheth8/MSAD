# Financial Modeling Prep API key (server-side only — never NEXT_PUBLIC_).
# Get a key at https://site.financialmodelingprep.com/
FMP_API_KEY=

# Massive (formerly Polygon.io) API key — powers the multi-asset news feed (/news).
# Free tier works (5 req/min, 15-min delayed). Get one at https://polygon.io/dashboard
# Optional: when unset, the news feed falls back to FMP, then sample data.
MASSIVE_API_KEY=
# MASSIVE_API_BASE=https://api.polygon.io

# Anthropic API key — powers "the Lens": grounded AI explanations, bear/bull
# cases, "ask anything", and journal reasoning critiques. Get one at
# https://console.anthropic.com/. Optional: when unset, the app falls back to
# curated static explainers. Server-side only.
ANTHROPIC_API_KEY=
# Optional model overrides (defaults shown):
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_SMART=claude-sonnet-4-6
# ANTHROPIC_MODEL_DEEP=claude-opus-4-8

# --- Accounts (all optional) -------------------------------------------------
# Set all three to enable "Sign in with Google" + cross-device progress sync.
# When unset, the app runs in guest mode: progress is saved in the browser
# (localStorage) and never lost on this device.
# Create OAuth creds at https://console.cloud.google.com/apis/credentials and add
#   <your-origin>/api/auth/google/callback as an Authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# A long random string used to sign session cookies, e.g. `openssl rand -hex 32`.
AUTH_SECRET=
# The app's public origin (optional). Auto-detected from the request URL on
# Vercel and locally. Set this only for a custom domain, e.g. https://msad.app
# AUTH_URL=https://msad.app
#
# Google OAuth: in Cloud Console → Credentials → your OAuth client, add these
# Authorized redirect URIs (exact match required):
#   http://localhost:3000/api/auth/google/callback
#   https://msad-alpha.vercel.app/api/auth/google/callback

# Brokerage import (optional) — read-only real holdings via SnapTrade, used by
# the Portfolio Risk X-ray. Requires a signed-in user (Google auth above). When
# unset, the X-ray simply uses manual entry. Get keys at https://snaptrade.com/
#
# Key types (see https://docs.snaptrade.com/docs/personal-vs-commercial):
#   PERS-*  Personal — for your own accounts; uses SnapTrade OAuth (no registerUser).
#           Add this redirect URI in the SnapTrade dashboard:
#             http://localhost:3000/api/brokerage/oauth/callback
#             https://msad-alpha.vercel.app/api/brokerage/oauth/callback
#   Other   Commercial — for multi-user apps; one SnapTrade user per MSAD user.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# Durable cross-device storage for signed-in profiles (optional). Without this,
# signed-in profiles persist only in-process (fine for local dev; on serverless
# the browser's localStorage copy remains the durable source). Vercel KV / any
# Upstash Redis REST endpoint works. Also powers rate limiting and shared caches.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Error monitoring (optional). When set, server errors are reported to Sentry.
# SENTRY_DSN=

# SnapTrade webhook secret (optional). Register POST /api/brokerage/webhook in
# the SnapTrade dashboard and set this to verify incoming events.
# SNAPTRADE_WEBHOOK_SECRET=
